{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "allowSyntheticDefaultImports": true
  },

  "include": [
    "src/server/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}