rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuth() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data)
        || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data)
        || request.resource.data.uid == resource.data.uid;
    }
    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function onlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function validStr(field, min, max) {
      return request.resource.data[field] is string
        && request.resource.data[field].size() >= min
        && request.resource.data[field].size() <= max;
    }

    // ── Users ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Documents (CV, Portfolio, Startup)
      match /documents/{docId} {
        function validDoc() {
          return hasFields(['uid', 'data', 'updatedAt'])
            && onlyFields(['uid', 'data', 'updatedAt'])
            && request.resource.data.uid is string
            && validStr('data', 0, 500000)
            && request.resource.data.updatedAt is timestamp;
        }
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && validDoc() && uidUnchanged();
        allow update: if isOwner(userId) && validDoc() && uidNotModified();
        allow delete: if isOwner(userId);
      }
    }

    // ── Events ────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isDocOwner();
      allow delete: if isAuth() && isDocOwner();
    }

    // ── Services ──────────────────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isDocOwner();
      allow delete: if isAuth() && isDocOwner();
    }

    // ── Communities / Pannels ─────────────────────────────────────────
    match /pannels/{pannelId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isDocOwner();
      allow delete: if isAuth() && isDocOwner();
    }

    // ── Messages ──────────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.members;
      allow delete: if false;

      match /messages/{msgId} {
        allow read:   if isAuth();
        allow create: if isAuth();
        allow update: if isAuth() && resource.data.senderId == request.auth.uid;
        allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // ── Notifications ─────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
